# ============================================================
# Root Environment — values consumed by docker-compose.yml
# Copy to .env and fill in your secrets.
# ============================================================

# PostgreSQL
POSTGRES_DB=csp_db
POSTGRES_USER=csp_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=change_me_redis_password
REDIS_PORT=6379

# Service ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
