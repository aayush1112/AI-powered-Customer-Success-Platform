# ============================================================
# Backend Environment Configuration
# Copy to .env and fill in your values.
# ============================================================

# ── Application ─────────────────────────────────────────────
APP_NAME="Customer Success Platform API"
APP_VERSION="0.1.0"
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ── API ─────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1

# ── Security — CHANGE THESE IN PRODUCTION ───────────────────
SECRET_KEY=super-secret-key-change-me-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── PostgreSQL ───────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://csp_user:csp_password@localhost:5432/csp_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ───────────────────────────────────────────────────
# Format: redis://:password@host:port/db
REDIS_URL=redis://:csp_redis_password@localhost:6379/0

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
